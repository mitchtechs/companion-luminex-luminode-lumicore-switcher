{
	"extends": "@companion-module/tools/tsconfig/node22/recommended",
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules/**"],
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"paths": {
			"*": ["./node_modules/*"]
		},
		"module": "Node16",
		"moduleResolution": "Node16"
	}
}
