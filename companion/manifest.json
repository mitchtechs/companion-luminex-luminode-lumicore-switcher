{
    "$schema": "../node_modules/@companion-module/base/assets/manifest.schema.json",
    "type": "connection",
    "id": "pda-luminex-luminode-lumicore-switcher",
    "name": "Luminex LumiNode / LumiCore Input Switcher",
    "shortname": "LumiSwitch",
    "description": "Switch input sources on Luminex LumiNode and LumiCore process engines via Art-Net control channel.",
    "version": "1.0.0",
    "license": "MIT",
    "repository": "git+https://github.com/bitfocus/companion-module-luminex-luminode-lumicore-switcher.git",
    "bugs": "https://github.com/bitfocus/companion-module-luminex-luminode-lumicore-switcher/issues",
    "maintainers": [
        {
            "name": "Mitch Bailey",
            "email": "mitch@pda-tech.com",
            "github": "mitchtechs",
            "url": "https://pda-tech.com"
        }
    ],
    "runtime": {
        "type": "node22",
        "api": "nodejs-ipc",
        "apiVersion": "0.0.0",
        "entrypoint": "../dist/main.js",
        "permissions": {
            "filesystem": true
        }
    },
    "legacyIds": [],
    "manufacturer": "Luminex",
    "products": [
        "LumiNode (Input Switcher)",
        "LumiCore (Input Switcher)"
    ],
    "keywords": [
        "Lighting",
        "DMX",
        "Art-Net",
        "Luminex",
        "LumiNode",
        "LumiCore",
        "Switcher"
    ],
    "bonjourQueries": {
        "luminode_host": [
            {
                "type": "_http",
                "protocol": "tcp",
                "port": 80
            },
            {
                "type": "luminex",
                "protocol": "tcp"
            }
        ]
    }
}